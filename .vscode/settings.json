{
    

    "memory-view.showMemoryPanel": true,
    "[c]":{
        "editor.lineNumbers": "off"
    },
    "[plaintext]":{
        "editor.lineNumbers": "off",

    },
    
    "workspaceKeybindings.codecrafters.enabled": true,
    "files.associations": {
        "*.ejs": "html",
        "__hash_table": "c",
        "array": "c",
        "complex": "c",
        "type_traits": "c",
        "limits": "c",
        "ratio": "c",
        "variant": "c"
    } // setting can be anything you want

}