{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "build_server",
            "command": "gcc",
            "args": [
                // "-fcolor-diagnostics",
                // "-fansi-escape-codes",
                "-g",
                "-Wno-format",
                // "-fsanitize=address",
                "${workspaceFolder}/app/server.c",
                "-o",
                "${workspaceFolder}/bin/codecrafters-build-redis-c",
                "-lm"
            ],
            "presentation": {
                "echo": true,
                "reveal": "silent",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": true
            },
            "options": {
                "cwd": "${workspaceFolder}/bin"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        },
        {
            "type": "shell",
            "label": "codecrafter test",
            "command": "make",
            "args": [
                // "debug"
                // "test_repl_with_redis"
                // "test_streams_with_redis"
                // "test_txn_with_redis"
                // "test_list_with_redis"
                // "test_pubsub_with_redis"
                // "test_zset_with_redis"
                // "test_geospatial_with_redis"
                // "test_base_with_redis"
                "test_all_with_redis"
            ],
            "options": {
                "cwd": "${workspaceFolder}/../tester-redis"
            },
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": "**/*.txt"
            },
            "presentation": {
                "echo": true,

                "focus": true,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": true
            },
            "dependsOn": ["cppbuild"]

        }
    ]
}